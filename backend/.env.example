# Database
POSTGRES_USER=agenticflow_user
POSTGRES_PASSWORD=agenticflow_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agenticflow_db

# Frontend URL for redirects
FRONTEND_URL=http://localhost:5173

# LTI/OAuth hardening
LTI_MAX_TIMESTAMP_AGE_SECONDS=300

# Google OAuth (required for private, user-scoped LTI credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Optional: if not set, backend computes callback from request host/proxy headers
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback

# Auth JWT secret (or use NEXTAUTH_SECRET as fallback)
AUTH_JWT_SECRET=change_me_to_a_long_random_secret
# NEXTAUTH_SECRET=optional_fallback_secret

# LLM / embeddings
OLLAMA_BASE_URL=http://localhost:11434
VALIDATION_MODEL=llama3.2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VALID_THRESHOLD=0.6
